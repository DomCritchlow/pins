# Copy to .env and fill in your values. .env is gitignored.
# Run `python3 scripts/build-config.py` to generate config.js from this file.

PINS_CLIENT_ID=XXXXX.apps.googleusercontent.com
PINS_API_KEY=XXXX

# Optional — these have sensible defaults.
PINS_SHEET_NAME_PREFIX=PlaceTracker
PINS_ADMIN_CONTACT=dominic@critchlow.us
